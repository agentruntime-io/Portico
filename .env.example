# Copy to .env.local and adjust for your machine.

# --- Production / Vercel (two variables for most setups) ---

# Clone this docs repo at build time (git URL, .git suffix is fine):
CONTENT_GIT_REPO=https://github.com/your-org/your-docs.git

# Public site URL (sitemap, canonical links, Open Graph):
SITE_URL=http://localhost:3004

# --- Optional ---

# Docs branch (defaults to main) — used for git clone and "Edit this page" links:
# CONTENT_GIT_BRANCH=main

# Local path instead of clone (dev only — do not set with CONTENT_GIT_REPO on Vercel):
# CONTENT_ROOT=/absolute/path/to/your-docs

# Override edit-link repo URL only if it differs from CONTENT_GIT_REPO (without .git):
# CONTENT_REPO_URL=https://github.com/your-org/your-docs

# Default Open Graph / Twitter card image (absolute URL or path on this site)
# SITE_OG_IMAGE=/og-default.png
