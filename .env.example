# Copy to .env.local and adjust paths for your machine.

# --- Content (pick one approach) ---

# Absolute path to a docs repo on disk (docs.json + MDX):
# CONTENT_ROOT=/path/to/your-docs

# Or clone at build time (Vercel / CI) — do not set CONTENT_ROOT when using this:
# CONTENT_GIT_REPO=https://github.com/your-org/your-docs.git
# CONTENT_GIT_BRANCH=main

# If unset locally, resolution order is documented in SELF_HOSTING.md
# (defaults to examples/demo-docs when no sibling agentruntime-docs exists).

# Public site URL (metadata, sitemap, search index, canonical URLs)
SITE_URL=http://localhost:3004

# Default Open Graph / Twitter card image (absolute URL or path on this site)
# SITE_OG_IMAGE=/og-default.png

# GitHub URL for "Edit this page" links (optional override)
# CONTENT_REPO_URL=https://github.com/your-org/your-docs
