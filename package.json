{
  "name": "portico",
  "version": "0.1.0",
  "description": "Portico — self-hosted documentation portal from AgentRuntime (https://www.agentruntime.io). Open source.",
  "private": false,
  "author": "AgentRuntime <https://www.agentruntime.io>",
  "homepage": "https://www.agentruntime.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agentruntime-io/Portico.git"
  },
  "bugs": {
    "url": "https://github.com/agentruntime-io/Portico/issues"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "documentation",
    "docs-site",
    "docs-as-code",
    "mdx",
    "openapi",
    "api-reference",
    "nextjs",
    "self-hosted",
    "portico",
    "agentruntime"
  ],
  "scripts": {
    "prebuild": "node scripts/prepare-content.mjs && node scripts/generate-search.mjs",
    "dev": "next dev -p 3004",
    "build": "next build",
    "start": "next start -p 3004",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "validate": "node scripts/validate-content.mjs"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@tailwindcss/typography": "^0.5.19",
    "gray-matter": "^4.0.3",
    "hast-util-to-text": "^4.0.2",
    "js-yaml": "^4.1.1",
    "lucide-react": "^1.18.0",
    "mermaid": "^11.15.0",
    "next": "16.2.6",
    "next-mdx-remote": "^6.0.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-pretty-code": "^0.14.3",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "server-only": "^0.0.1",
    "shiki": "^4.2.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^6"
  }
}
